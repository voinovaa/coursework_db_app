<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.PartsController"
      spacing="10"
      style="-fx-padding: 20;">

    <Label text="Детали" style="-fx-font-size: 20;"/>

    <TableView fx:id="partsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="nameColumn" text="Название" prefWidth="200"/>
            <TableColumn fx:id="articleColumn" text="Артикул" prefWidth="150"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <TextField fx:id="nameField" promptText="Название" prefWidth="200"/>
        <TextField fx:id="articleField" promptText="Артикул" prefWidth="150"/>
    </HBox>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>

    <HBox spacing="10">
        <Button text="Добавить" onAction="#handleAdd"/>
        <Button text="Изменить" onAction="#handleEdit"/>
        <Button text="Удалить" onAction="#handleDelete"/>
        <Button text="Назад" onAction="#handleBack"/>
    </HBox>

</VBox>