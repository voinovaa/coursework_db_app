<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.SuppliersController"
      spacing="10"
      style="-fx-padding: 20;">

    <Label text="Поставщики" style="-fx-font-size: 20;"/>

    <TableView fx:id="suppliersTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="nameColumn" text="Название" prefWidth="150"/>
            <TableColumn fx:id="addressColumn" text="Адрес" prefWidth="200"/>
            <TableColumn fx:id="phoneColumn" text="Телефон" prefWidth="130"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <TextField fx:id="nameField" promptText="Название" prefWidth="150"/>
        <TextField fx:id="addressField" promptText="Адрес" prefWidth="200"/>
        <TextField fx:id="phoneField" promptText="Телефон" prefWidth="130"/>
    </HBox>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>

    <HBox spacing="10">
        <Button text="Добавить" onAction="#handleAdd"/>
        <Button text="Изменить" onAction="#handleEdit"/>
        <Button text="Удалить" onAction="#handleDelete"/>
        <Button text="Назад" onAction="#handleBack"/>
    </HBox>

</VBox>